---
import BaseHead from '../components/BaseHead.astro';
import HomeStage from '../components/HomeStage.vue';
import illustration from '../assets/illustration.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={illustration} />
	</head>
	<body class="home-document">
		<HomeStage client:load illustrationUrl={illustration.src} />
	</body>
</html>

<style is:global>
	body.home-document {
		margin: 0;
		background: #ffffff;
		color: #ffffff;
		font-family:
			Inter,
			Montserrat,
			'Noto Sans SC',
			'Microsoft YaHei',
			var(--font-atkinson),
			sans-serif;
		font-size: 16px;
		line-height: 1.5;
		overflow-x: hidden;
	}

	body.home-document a {
		color: inherit;
	}
</style>
