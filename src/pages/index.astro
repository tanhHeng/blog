---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import '../styles/global.scss';
---

<DefaultLayout>
	<div class="left-content">
		<div class="left-container">
			<section class="main-content is-active">
				<div class="subtitle">
					<p>Welcom to</p>
					<img src="/svg/X.svg" alt="X"/>
					<img src="/svg/X.svg" alt="X"/>
					<img src="/svg/X.svg" alt="X"/>
				</div>
				<h1 class="title">tanh_Heng's Blog</h1>
				<div class="signature">
					<div class="circles-grid">
						{Array.from({ length: 40 }).map(() => (
							<span class="circle"></span>
						))}
					</div>
					<p>Life is Piano.</p>
				</div>
			</section>
			<section class="aboutme-content" hidden>
				<p class="title">About Me</p>
				<p class="text">这里是 tanh丶桁~一名深度学习爱好者，同时也是业余平面设计师，在代码、算法与视觉之间反复横跳的交叉领域探索者。<br>我热衷于用技术解决实际问题，也用设计表达技术背后的温度。GitHub 是我沉淀技术思考、与社区协作共创的地方——你看到的每个仓库都是我某一领域的实践痕迹。</p>
				<div class="tags">
					<p class="tag-title">language</p>
					{Array.from(["python", "java"]).map((lang) => (
						<p class="tag">{lang}</p>
					))}
				</div>
				<div class="tags">
					<p class="tag-title">interest</p>
					{Array.from(["sleep", "eat", "graphic design", "deep learning"]).map((lang) => (
						<p class="tag">{lang}</p>
					))}
				</div>
			</section>
			<section class="recent-content" hidden>
				<p class="title">Recent</p>
				<div class="recent-container">
					<p class="recent-index">01</p>
					<div class="recent-info">
						<p class="recent-title">此功能仍在开发中</p>
						<div class="recent-detail">
							<p>2026-07-17</p>
							<p>Developing</p>
						</div>
					</div>
				</div>
			</section>
			<section class="footpage-content" hidden>
				<p class="signature">Life is Piano. You are Pianist.</p>
				<p class="footnote">tanh.moe | Personal Blog | All Rights Reserved</p>
			</section>
		</div>
	</div>
</DefaultLayout>

<script is:inline>
  (function() {
    const sections = Array.from(document.querySelectorAll('.left-container section'));
    let currentSectionIndex = 0;
    let isTransitioning = false;
    const animationClasses = [
      'animate__animated',
      'animate__fadeInUp',
      'animate__fadeInDown',
      'animate__fadeOutUp',
      'animate__fadeOutDown',
    ];
    
    function transitionTo(nextSectionIndex, direction) {
      const currentSection = sections[currentSectionIndex];
      const nextSection = sections[nextSectionIndex];
      const entranceAnimation = direction === 'down' ? 'animate__fadeInUp' : 'animate__fadeInDown';
      const exitAnimation = direction === 'down' ? 'animate__fadeOutUp' : 'animate__fadeOutDown';

      isTransitioning = true;
      nextSection.hidden = false;
      currentSection.classList.remove(...animationClasses, 'is-active');
      nextSection.classList.remove(...animationClasses);
      currentSection.classList.add('is-leaving', 'animate__animated', exitAnimation);
      nextSection.classList.add('is-active', 'animate__animated', entranceAnimation);

      let completedAnimations = 0;
      const finishTransition = function() {
        completedAnimations += 1;
        if (completedAnimations !== 2) return;

        currentSection.hidden = true;
        currentSection.classList.remove(...animationClasses, 'is-leaving');
        nextSection.classList.remove(...animationClasses);
        currentSectionIndex = nextSectionIndex;
        isTransitioning = false;
      };

      currentSection.addEventListener('animationend', finishTransition, { once: true });
      nextSection.addEventListener('animationend', finishTransition, { once: true });
    }

    window.addEventListener('wheel', function(e) {
      e.preventDefault();
      if (isTransitioning || e.deltaY === 0) return;

      const direction = e.deltaY > 0 ? 'down' : 'up';
      const nextSectionIndex = currentSectionIndex + (direction === 'down' ? 1 : -1);
      if (nextSectionIndex < 0 || nextSectionIndex >= sections.length) return;

      transitionTo(nextSectionIndex, direction);
    }, { passive: false });
  })();
</script>

<style scoped lang="scss">
@use '../styles/global.scss' as *;
@use '../styles/Navbar.scss' as navbar;

body, html {
	overflow: hidden;
}

p {
	margin: 0;
}

.left-container section[hidden] {
	display: none;
}

.animate__animated.animate__fadeInUp,
.animate__animated.animate__fadeInDown,
.animate__animated.animate__fadeOutUp,
.animate__animated.animate__fadeOutDown {
  --animate-duration: 600ms;
}

.left-content {
	display: flex;
	flex-direction: column;
	align-items: center;
	// position:;
	width: calc(100vw - 70.5vh);
	height: calc(100vh - navbar.$navbar-actual-height);
}

.left-container {
	width: 40rem;
	section {
		position: absolute;
		width: 40rem;
		margin-top: 23vh;
		// animation-duration: 1s;
	}
}

.title {
	font-family: $font-family-default;
	font-size: $font-size-title;
	color: $home-title-color;
	margin: 0;
	font-weight: 500;
}

.main-content {
	display: flex;
	flex-direction: column;
	margin-top: 23vh;
	.subtitle {
		display: flex;
		gap: 1rem;
		p {
			font-family: $font-family-default;
			font-size: $font-size-larger-2;
			color: $primary-blue;
			margin: 0;
			line-height: 1;
		}
		img {
			width: $font-size-larger-2;
			height: $font-size-larger-2;
		}
	}
	.signature {
		display: flex;

		margin-top: 2rem;

		.circles-grid {
			display: grid;
			grid-template-columns: repeat(10, 0.5rem);
			grid-template-rows: repeat(4, 0.5rem);
			gap: 2rem;
			
			.circle {
				width: 0.5rem;
				height: 0.5rem;
				border-radius: 50%;
				background-color: $ex-light-blue;
			}
		}

		p {
			font-family: $font-family-special;
			font-size: $font-size-title;
			color: $light-blue;
			margin-left: 2rem;
			margin-top: -0.5rem;
			line-height: 1;
		}
	}
}


.aboutme-content {

	display: flex;
	flex-direction: column;
	gap: 1rem;

	.text {
		font-family: $font-family-chinese;
		font-size: $font-size-content;
		color: $content-color;
		line-height: 2;
		margin: 0;
	}

	.tags {
		display: flex;
		align-items: left;
		gap: 1rem;
		margin: 0;
		color: $primary-blue;
		font-family: $font-family-heading;
		line-height: 1;

		.tag-title {
			font-weight: bold;
			margin: 0;
		}

		.tag {
			font-weight: normal;
			margin: 0;
		}
	}
}

.recent-content {
	display: flex;
	flex-direction: column;
	gap: 1rem;

	.recent-container {
		display: flex;
		flex-direction: row;
		gap: 1rem;
		font-size: $font-size-larger-1;

		.recent-index {
			font-family: $font-family-default;
			width: 2rem;
			height: 2rem;
			text-align: center;
			color: #FFFFFF;
			background-color: $primary-blue;
		}

		.recent-title {
			font-family: $font-family-chinese;
			color: $content-color;
			line-height: 1;
		}

		.recent-detail {
			display: flex;
			flex-direction: row;
			gap: 1rem;
			font-size: $font-size-content;
			color: $light-blue;
			line-height: 2;
		}

	}
}

.footpage-content {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 0;

	.signature {
		margin-top: 5vh;
		font-size: 4rem;
		font-family: $font-family-special;
		color: $primary-blue;
		letter-spacing: 2px;
	}
	.footnote {
		font-size: $font-size-larger-1;
		font-weight: 500;
		color: $light-blue;
	}
}

</style>
