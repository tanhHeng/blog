---
import BaseLayout from './BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import TextDecorations from '../components/TextDecorations.astro';

interface Props {
  activePage?: string;
  showHero?: boolean;
  showTextDecorations?: boolean;
  leftText?: string;
  rightText?: string;
  heroImage?: string;
}

const {
  activePage,
  showHero = true,
  showTextDecorations = true,
  leftText,
  rightText,
  heroImage,
} = Astro.props;
---

<BaseLayout activePage={activePage}>
  {showTextDecorations && (
    <TextDecorations leftText={leftText} rightText={rightText} />
  )}
  <slot />
  {showHero && <HeroSection imageSrc={heroImage} />}
</BaseLayout>

<style scoped lang="scss">
slot {
  width: calc(100vw - 70.5vh);
}
</style>
